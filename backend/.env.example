# BrushIQ Backend Configuration Example
# Copy this file to .env and configure for production.

# Server Port
PORT=5000

# Environment Mode
NODE_ENV=production

# JWT Authentication Secret Key
JWT_SECRET=yoursupersecurejwtsecretkeygoeshere

# Mode: set to false to use PostgreSQL / Supabase, or true for local JSON DB
DEMO_MODE=false

# PostgreSQL Database Configuration
DB_HOST=your-supabase-db-host.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-supabase-db-password
DB_DATABASE=postgres
